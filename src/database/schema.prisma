// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole{
  ADMIN
  SERVICE_PROVIDER
  BUSINESS_OWNER
}

enum BookingStatus {
  PENDING     // pendiente
  IN_PROGRESS // en proceso
  DONE        // terminado
}

enum MovementType {
  INCOME   // ingreso
  EXPENSE  // egreso
}
 
enum FrequencyType {
  NEW        // nuevo
  RECURRING  // recurrente
}

model Role{
  id String @id @default(uuid())
  name String @unique
  isActive Boolean

  //Relaciones
  users User[]

  //Timestamp
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id String @id @default(uuid())

   // Información personal
  name String
  lastName String @map("last_name")
  username String @unique
  email String @unique
  password String
  phone String?

  //Logica de negocio
  isActive Boolean @default(true) @map("is_active")
  goal Decimal @default(0) @db.Decimal(10, 2)
 
  //Sistema de referidos 
  /* referralCode String? @unique @map("referral_code")
  referredById String? @map("referred_by") */

  //Relaciones
  role Role @relation(fields: [roleId], references: [id])
  roleId String

  

  businessId String? @map("business_id")
  business Business? @relation(fields: [businessId], references: [id])
  ownedBusiness Business? @relation("BusinessOwner")
  resetTokens ResetToken[]
  refreshTokens RefreshToken[]
  movements Movement[]
  bookings Booking[]

  //Periodo de prueba y pago 
  trialPeriodEndsAt DateTime? @map("trial_ends_at")
  paymentPeriodEndsAt DateTime? @map("payment_ends_at")

  //Timestamp
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Business {
  id String @id @default(uuid())
  
  name String?
  goal Decimal @default(0) @db.Decimal(10, 2)
  type String?
  imageUrl String? @map("image_url")
  description String?
  businessJoinCode String @unique @map("business_join_code")

  //Relaciones
  ownerId String @unique @map("owner_id")
  owner User @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  employees User[]
  movements Movement[]

  //Timestamp
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([businessJoinCode])
  @@map("businesses")
}

model ResetToken {
  id String @id @default(uuid())
  
  token String @unique
  used Boolean @default(false)
  expiresAt DateTime @map("expires_at")
  
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([expiresAt])

  @@map("reset_tokens")
}

model RefreshToken {
  id String @id @default(uuid())
   
  token String @unique
  expiresAt DateTime @map("expires_at")
  revoked Boolean @default(false)
  
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([token])
  @@index([userId])

  @@map("refresh_tokens")
}

model Movement {
  id          String        @id @default(uuid())
 
  type        MovementType
  frequency   FrequencyType?
  value       Decimal       @db.Decimal(12, 2)
  description String?       
  date        DateTime      @db.Date

  // Relaciones
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  businessId  String        @map("business_id")
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
 
  // Timestamps
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  @@index([userId])
  @@index([businessId])
  @@index([userId, date])       // Cubre: resumen diario/mensual por usuario
  @@index([businessId, date])   // Cubre: resumen diario/mensual por negocio
  @@index([date])               // Cubre: queries globales por fecha
 
  @@map("movements")
}

model TimeSlot {
  id        String   @id @default(uuid())

  hour      String                        // "08:00", "09:00", etc.
  isActive  Boolean  @default(true)       @map("is_active")

  // Relaciones
  bookings  Booking[]

  // Timestamps
  createdAt DateTime @default(now())      @map("created_at")
  updatedAt DateTime @updatedAt           @map("updated_at")

  @@map("time_slots")
}

model Booking {
  id           String        @id @default(uuid())

  date         DateTime      @db.Date
  customerName String?       @map("customer_name")
  description  String?
  status       BookingStatus @default(PENDING)

  // Relaciones
  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  timeSlotId   String        @map("time_slot_id")
  timeSlot     TimeSlot      @relation(fields: [timeSlotId], references: [id])

  // Timestamps
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt      @map("updated_at")

  // Un usuario no puede reservar el mismo slot dos veces en el mismo día
  @@unique([date, timeSlotId, userId])

  @@index([userId])
  @@index([userId, date])     // Cubre: consultas de disponibilidad y listados por día
  @@index([timeSlotId])

  @@map("bookings")
}